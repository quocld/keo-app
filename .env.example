# Copy to .env.local (gitignored) for local prebuild/dev client builds.
# Do not commit real keys. Rotate keys if they were ever exposed.
# Google Cloud: enable Maps SDK for Android + iOS; restrict key by package/bundle + SHA-1 (Android).
# After setting the key, rebuild native binaries: `npx expo prebuild` then run ios/android, or EAS Build.
GOOGLE_MAPS_API_KEY=
